# Songrank is a static SPA with no backend — there are no server
# secrets. Spotify creds are pasted by each user on /setup and live in
# their browser's localStorage only.
#
# The one optional env var is the GitHub Pages basePath, used in CI so
# asset URLs resolve under /bracketeering/ (path stays for OAuth
# redirect compatibility — the repo was renamed but the deploy path
# can't change without breaking every user's Spotify dev app). Local
# dev leaves it empty.
NEXT_PUBLIC_BASE_PATH=
