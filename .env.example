# --- Spotify ---
# Each end-user supplies their own Client ID + Secret on the /setup page
# (Spotify Dev Mode caps personal apps at 5 users; BYO sidesteps this).
# Only the redirect URI is server-controlled — each user adds it to *their*
# Spotify dev app's allowed redirect URIs.
# Spotify rejects http://localhost since Apr 2025 — must use 127.0.0.1 for HTTP loopback.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

# --- iron-session encryption key (32+ chars). Generate: openssl rand -hex 32 ---
SESSION_PASSWORD=

# --- BYO Client Secret encryption key (AES-256-GCM, hex-32). openssl rand -hex 32 ---
BYO_ENCRYPTION_KEY=

# --- Supabase (from ~/.secrets/side-projects.gpg via inject-side-project-secrets) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Base URL for OAuth redirect computation ---
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3000
